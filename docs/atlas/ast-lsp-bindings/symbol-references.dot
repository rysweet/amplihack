digraph symbol_references {
    rankdir=LR;
    fontname="Helvetica";
    node [fontname="Helvetica", shape=box, style="filled,rounded"];
    edge [fontname="Helvetica", fontsize=9];
    label="amplihack Cross-Module Symbol References\n(Mode: static-approximation)";
    labelloc=t;
    fontsize=14;
    nodesep=0.5;
    ranksep=1.2;

    // Entry / CLI layer
    subgraph cluster_entry {
        label="Entry / CLI";
        style=filled;
        fillcolor="#e1f5fe";
        root [label="__root__\ncli.py, session.py", fillcolor="#bbdefb"];
        recipe_cli [label="recipe_cli", fillcolor="#bbdefb"];
        plugin_cli [label="plugin_cli", fillcolor="#bbdefb"];
    }

    // Core modules
    subgraph cluster_core {
        label="Core Modules";
        style=filled;
        fillcolor="#f3e5f5";
        launcher [label="launcher\n87 symbols", fillcolor="#ce93d8"];
        fleet [label="fleet\n122 symbols", fillcolor="#ce93d8"];
        proxy [label="proxy\n113 symbols", fillcolor="#ce93d8", style="filled,rounded,dashed"];
        memory [label="memory\n91 symbols", fillcolor="#ce93d8"];
        recipes [label="recipes\n27 symbols", fillcolor="#ce93d8"];
    }

    // Agent system
    subgraph cluster_agents {
        label="Agent System";
        style=filled;
        fillcolor="#fff3e0";
        agents [label="agents\n100 symbols\n14 imported", fillcolor="#ffcc80"];
        eval [label="eval\n27 files", fillcolor="#ffcc80"];
        goal_gen [label="goal_agent_gen\n36 symbols", fillcolor="#ffcc80"];
        meta [label="meta_delegation\n30 symbols", fillcolor="#ffcc80"];
    }

    // Infrastructure
    subgraph cluster_infra {
        label="Infrastructure";
        style=filled;
        fillcolor="#fce4ec";
        hooks [label="hooks", fillcolor="#ef9a9a"];
        safety [label="safety", fillcolor="#ef9a9a"];
        utils [label="utils\n81 symbols", fillcolor="#ef9a9a"];
        settings_gen [label="settings_gen", fillcolor="#ef9a9a"];
        exceptions [label="exceptions", fillcolor="#ef9a9a"];
        workflows [label="workflows", fillcolor="#ef9a9a"];
    }

    // Vendored
    subgraph cluster_vendor {
        label="Vendored";
        style=filled;
        fillcolor="#fff9c4";
        vendor [label="vendor/blarify\nGraphBuilder\nKuzuManager\nscip_pb2", fillcolor="#fff176"];
    }

    // Heaviest edge: eval -> agents
    eval -> agents [
        label="LearningAgent\ncreate_agent\nDomainAgent\nCognitiveAdapter\n+8 more (37 refs)",
        penwidth=4,
        color="#ef6c00"
    ];

    // __root__ edges
    root -> fleet [label="fleet_cli"];
    root -> launcher [label="SettingsManager"];
    root -> exceptions [label="errors"];

    // launcher edges
    launcher -> hooks [label="execute_stop_hook"];
    launcher -> safety [label="PromptTransformer"];

    // fleet -> memory
    fleet -> memory [label="store_discovery\nget_recent_discoveries"];

    // recipe_cli -> recipes
    recipe_cli -> recipes [label="RecipeParser\nRecipe\nRecipeResult"];

    // workflows -> recipes
    workflows -> recipes [label="run_recipe_by_name"];

    // goal_agent_generator -> launcher
    goal_gen -> launcher [label="AutoMode"];

    // meta_delegation -> utils
    meta -> utils [label="get_agent_binary"];

    // utils -> settings_gen
    utils -> settings_gen [label="write_json_atomic"];

    // memory -> vendor
    memory -> vendor [label="GraphBuilder\nKuzuManager\nscip_pb2", style=dashed];

    // Isolated nodes (no cross-module imports - zero external consumers)
    // proxy has style=dashed to indicate it's imported only by examples
    // plugin_cli, security, testing, etc. are omitted as they have zero edges
}
