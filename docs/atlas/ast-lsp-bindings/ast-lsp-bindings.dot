digraph ast_lsp_bindings {
    rankdir=LR;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10];
    edge [color="#666666"];

    // Public API nodes as record shapes
    node [shape=record, style="filled", fillcolor="#e8f4fd"];

    amplihack [label="{amplihack/__init__|main()\linstall()\luninstall()\lensure_dirs()\lcopytree_manifest()\l}"];
    settings [label="{settings|ensure_settings_json()\lupdate_hook_paths()\l}"];
    launcher [label="{launcher|ClaudeLauncher\lClaudeDirectoryDetector\lPrerequisiteChecker\lAutoStager\lClaudeBinaryManager\l}"];
    security [label="{security|scan()\lSecurityScanner\l}"];
    safety [label="{safety|StagingGuard\l}"];
    docker [label="{docker|DockerDetector\lDockerManager\l}"];
    uvx [label="{uvx|UVXManager\l}"];
    utils [label="{utils|slugify()\lclaude_cli\lprerequisites\ldefensive\l}"];
    recipes [label="{recipes|RecipeParser\lrun_recipe_via_rust()\ldiscover_recipes()\l}"];
    recipe_cli [label="{recipe_cli|create_recipe_subparser()\lhandle_recipe_command()\l}"];
    fleet [label="{fleet|FleetObserver\lFleetCLI\lSessionContext\l}"];
    knowledge [label="{knowledge_builder|KnowledgeBuilder\lKnowledgeGraph\l}"];
    bundle [label="{bundle_generator|BundleBuilder\lBundlePackager\l}"];
    workflows [label="{workflows|WorkflowEngine\l}"];
    settings_gen [label="{settings_generator|SettingsGenerator\l}"];
    rust_trial [label="{rust_trial|InstallOptions\ldefault_trial_home()\ldefault_install_dir()\lparse_install_args()\linstall_rust_cli()\lrun_rust_trial()\lmain()\l}"];
    power [label="{power_steering|prompt_re_enable_if_disabled()\l}"];
    lsp [label="{lsp_detector|LSPDetector\l}"];
    memory [label="{memory.discoveries|store_discovery()\lget_recent_discoveries()\l}"];
    eval_pkg [label="{eval|teaching_eval\lgrader\lprogressive_test_suite\l}"];
    hooks [label="{hooks|LauncherDetector\lLauncherInfo\l}"];
    context [label="{context.adaptive|LauncherDetector\lHookStrategy\lClaudeStrategy\lCopilotStrategy\l}"];
    vendor [label="{vendor.blarify|GraphBuilder\l}"];

    // Cross-package imports
    node [shape=ellipse, style="filled", fillcolor="#fff9c4"];
    cli [label="cli.py"];
    auto_mode [label="launcher/auto_mode"];
    fleet_copilot [label="fleet/fleet_copilot"];
    recipe_cmd [label="recipe_cli/command"];
    eval_harness [label="eval/*"];

    cli -> launcher [label="imports"];
    cli -> fleet [label="imports"];
    cli -> recipes [label="imports"];
    cli -> bundle [label="imports"];
    rust_trial -> launcher [label="imports\nlauncher.copilot helpers", color="#6666aa"];
    rust_trial -> amplihack [label="bootstraps\namplihack install", color="#6666aa"];

    auto_mode -> launcher [label="internal"];
    fleet_copilot -> fleet [label="internal"];
    recipe_cmd -> recipes [label="imports"];
    eval_harness -> eval_pkg [label="internal"];

    // Intra-module: recipes/rust_runner -> recipes/discovery
    node [shape=record, style="filled", fillcolor="#d4e8d4"];
    rust_runner [label="{recipes/rust_runner|contextlib, signal (stdlib)\los, json, subprocess\lRecipeResult, StepResult\l_project_dir_context()\l}"];
    discovery_mod [label="{recipes/discovery|os (stdlib)\lhashlib, json, subprocess\l_AMPLIHACK_HOME_BUNDLE_DIR\l_PACKAGE_BUNDLE_DIR\l_REPO_ROOT_BUNDLE_DIR\l}"];

    rust_runner_exec [label="{recipes/rust_runner_execution|build_rust_env()\lexecute_rust_command()\l_ALLOWED_RUST_ENV_VARS\l}"];
    rust_runner_copilot [label="{recipes/rust_runner_copilot|_create_copilot_compat_wrapper_dir()\l_normalize_copilot_cli_args()\l}"];
    rust_runner_resolution [label="{recipes/rust_runner_recipe_resolution|_default_package_recipe_dirs()\l_normalize_recipe_dirs()\l_resolve_recipe_target()\l}"];

    rust_runner -> discovery_mod [label="imports\n_AMPLIHACK_HOME_BUNDLE_DIR\n_PACKAGE_BUNDLE_DIR\n_REPO_ROOT_BUNDLE_DIR", color="#6666aa"]; // pragma: allowlist secret
    rust_runner -> rust_runner_exec [label="imports\nbuild_rust_env\nexecute_rust_command", color="#6666aa"];
    rust_runner -> rust_runner_copilot [label="imports\n_create_copilot_compat_wrapper_dir\n_normalize_copilot_cli_args", color="#6666aa"];
    rust_runner -> rust_runner_resolution [label="imports\n_default_package_recipe_dirs\n_normalize_recipe_dirs\n_resolve_recipe_target", color="#6666aa"];
    // Dead code candidates
    node [shape=box, style="dashed,filled", fillcolor="#ffcdd2"];
    dead1 [label="examples/usage_example.py\n(demo only)"];
    dead2 [label="examples/usage_example_llm.py\n(demo only)"];
    dead4 [label="copilot_auto_install.py"];
    dead5 [label="staging_cleanup.py"];

    // goal_seeking mixin refactor (PR #3894)
    subgraph cluster_goal_seeking {
        label="agents/goal_seeking";
        style="filled";
        fillcolor="#f0f8ff";
        node [shape=record, style="filled", fillcolor="#e8f4fd"];

        la [label="{learning_agent|LearningAgent (facade)\l__init__, retry, lifecycle\l}"];
        idm [label="{intent_detector|IntentDetectorMixin\l_detect_intent()\l}"];
        trm [label="{temporal_reasoning|TemporalReasoningMixin\l9 temporal methods\l}"];
        csm [label="{code_synthesis|CodeSynthesisMixin\l2 code gen methods\l}"];
        kum [label="{knowledge_utils|KnowledgeUtilsMixin\l15 utility methods\l}"];
        rsm [label="{retrieval_strategies|RetrievalStrategiesMixin\l20 retrieval methods\l}"];
        lim [label="{learning_ingestion|LearningIngestionMixin\l10 ingestion methods\l}"];
        asm [label="{answer_synthesizer|AnswerSynthesizerMixin\l4 synthesis methods\l}"];
        pu [label="{prompt_utils|_get_llm_completion()\l_load_prompt()\l}"];
    }

    la -> idm [label="inherits"];
    la -> trm [label="inherits"];
    la -> csm [label="inherits"];
    la -> kum [label="inherits"];
    la -> rsm [label="inherits"];
    la -> lim [label="inherits"];
    la -> asm [label="inherits"];
    idm -> pu [label="imports"];
    trm -> pu [label="imports"];
    csm -> pu [label="imports"];
    kum -> pu [label="imports"];
    rsm -> pu [label="imports"];
    lim -> pu [label="imports"];
    asm -> pu [label="imports"];
    pu -> la [label="sys.modules\nresolve", style="dashed", color="#999999"];

    // Test modules (bootstrap detection)
    node [shape=box, style="filled", fillcolor="#e8f5e9"];
    test_wf [label="{test_default_workflow_fixes|TestBL001\lTestBL002\lTestBL003\l}"];
}
