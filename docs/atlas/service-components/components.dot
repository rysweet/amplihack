digraph service_components {
    rankdir=TD;
    fontname="Helvetica";
    node [fontname="Helvetica", shape=box, style="filled,rounded"];
    edge [fontname="Helvetica", fontsize=10];
    label="amplihack Service Component Architecture\n(Cross-module import dependencies)";
    labelloc=t;
    fontsize=16;

    // Entry Points
    subgraph cluster_entry {
        label="Entry Points";
        style=filled;
        fillcolor="#e1f5fe";
        root [label="__root__\ncli.py, session.py\ninstall.py (22 files)", fillcolor="#bbdefb"];
    }

    // Core Services
    subgraph cluster_core {
        label="Core Services";
        style=filled;
        fillcolor="#f3e5f5";
        launcher [label="launcher\n26 files", fillcolor="#ce93d8"];
        proxy [label="proxy\n30 files", fillcolor="#ce93d8"];
        recipes [label="recipes\n6 files", fillcolor="#ce93d8"];
        memory [label="memory\n39 files", fillcolor="#ce93d8"];
        fleet [label="fleet\n55 files", fillcolor="#ce93d8"];
    }

    // Agent Subsystem
    subgraph cluster_agents {
        label="Agent Subsystem";
        style=filled;
        fillcolor="#fff3e0";
        agents [label="agents\n40 files", fillcolor="#ffcc80"];
        eval [label="eval\n27 files", fillcolor="#ffcc80"];
        goal_gen [label="goal_agent_generator\n12 files", fillcolor="#ffcc80"];
        meta [label="meta_delegation\n9 files", fillcolor="#ffcc80"];
    }

    // CLI Layer
    subgraph cluster_cli {
        label="CLI Layer";
        style=filled;
        fillcolor="#e8f5e9";
        recipe_cli [label="recipe_cli\n3 files", fillcolor="#a5d6a7"];
        plugin_cli [label="plugin_cli\n4 files", fillcolor="#a5d6a7"];
    }

    // Infrastructure
    subgraph cluster_infra {
        label="Infrastructure";
        style=filled;
        fillcolor="#fce4ec";
        hooks [label="hooks\n3 files", fillcolor="#ef9a9a"];
        safety [label="safety\n4 files", fillcolor="#ef9a9a"];
        security [label="security\n11 files", fillcolor="#ef9a9a"];
        utils [label="utils\n21 files", fillcolor="#ef9a9a"];
        exceptions [label="exceptions", fillcolor="#ef9a9a"];
        settings_gen [label="settings_generator\n2 files", fillcolor="#ef9a9a"];
    }

    // Support Modules
    subgraph cluster_support {
        label="Support Modules";
        style=filled;
        fillcolor="#f5f5f5";
        workflows [label="workflows\n6 files", fillcolor="#e0e0e0"];
        bundle_gen [label="bundle_generator\n17 files", fillcolor="#e0e0e0"];
        knowledge [label="knowledge_builder\n7 files", fillcolor="#e0e0e0"];
        docker [label="docker\n3 files", fillcolor="#e0e0e0"];
        context [label="context\n3 files", fillcolor="#e0e0e0"];
        mode [label="mode_detector\n3 files", fillcolor="#e0e0e0"];
        tracing [label="tracing\n2 files", fillcolor="#e0e0e0"];
        uvx [label="uvx\n2 files", fillcolor="#e0e0e0"];
        power [label="power_steering\n2 files", fillcolor="#e0e0e0"];
        lsp [label="lsp_detector\n2 files", fillcolor="#e0e0e0"];
        plugin_mgr [label="plugin_manager\n2 files", fillcolor="#e0e0e0"];
        path_res [label="path_resolver\n2 files", fillcolor="#e0e0e0"];
        testing [label="testing\n3 files", fillcolor="#e0e0e0"];
    }

    // Vendored
    subgraph cluster_vendor {
        label="Vendored";
        style=filled;
        fillcolor="#fff9c4";
        vendor [label="vendor/blarify", fillcolor="#fff176"];
    }

    // Cross-module edges
    root -> fleet [label="fleet_cli"];
    root -> launcher [label="SettingsManager"];
    root -> exceptions [label="errors"];

    eval -> agents [label="37 imports", penwidth=3, color="#ef6c00"];
    fleet -> memory [label="discoveries", style=dashed];
    goal_gen -> launcher [label="AutoMode"];
    meta -> utils [label="get_agent_binary"];

    launcher -> hooks [label="execute_stop_hook"];
    launcher -> safety [label="PromptTransformer"];

    recipe_cli -> recipes [label="RecipeParser\nRecipe"];
    workflows -> recipes [label="run_recipe_by_name"];

    memory -> vendor [label="GraphBuilder\nKuzuManager", style=dashed];
    utils -> settings_gen [label="write_json_atomic"];
}
