digraph service_components_pr3500 {
    rankdir=TB;
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded"];
    edge [fontname="Helvetica", fontsize=9];

    root [label="src/amplihack/__init__.py\nmain() + Rust-first delegation", style="filled", fillcolor="#d0bfff"];
    cli [label="src/amplihack/cli.py\nPython CLI fallback", style="filled", fillcolor="#dfe6e9"];
    rust_cli [label="Installed Rust CLI\n(external binary)", style="filled", fillcolor="#ffe8cc"];
    launcher [label="launcher/copilot.py\nstaged .github hook surface", style="filled", fillcolor="#b2f2bb"];

    subgraph cluster_recipes {
        label="recipes/";
        style=filled;
        fillcolor="#e9ecef";
        runner [label="rust_runner.py\nJSON orchestration"];
        execution [label="rust_runner_execution.py\nsubprocess + progress files"];
        binary [label="rust_runner_binary.py\nbinary discovery + version gating"];
        copilot [label="rust_runner_copilot.py\nnested Copilot normalization"];
        resolution [label="rust_runner_recipe_resolution.py\nrecipe lookup"];
        models [label="models.py\nRecipeResult / StepResult"];
    }

    root -> rust_cli [label="install / mode / recipe / update"];
    root -> cli [label="fallback"];
    cli -> runner;
    launcher -> runner [label="nested Copilot recipe path"];
    runner -> execution;
    runner -> binary;
    runner -> copilot;
    runner -> resolution;
    runner -> models;
}
