digraph compile_deps {
    rankdir=LR;
    node [shape=box, style=rounded, fontname="Helvetica"];
    edge [color="#666666"];

    subgraph cluster_ext {
        label="External Dependencies";
        style=filled; fillcolor="#f0f7ff";
        rich [label="rich\n20 imports"];
        requests [label="requests\n9 imports"];
        tree_sitter [label="tree-sitter\n16 imports"];
        kuzu [label="kuzu\n10 imports"];
        fastapi [label="fastapi\n6 imports"];
        aiohttp [label="aiohttp\n5 imports"];
        simpleeval [label="simpleeval\n4 imports"];
        langchain [label="langchain*\n26 imports"];
        azure_identity [label="azure-identity\n11 imports"];
        docker [label="docker\n3 imports"];
        neo4j [label="neo4j\n4 imports"];
        typing_ext [label="typing-extensions\n13 imports"];
    }

    subgraph cluster_sibling {
        label="Sibling Packages";
        style=filled; fillcolor="#fff7f0";
        memory_lib [label="amplihack-memory-lib\n12 imports"];
        agent_eval [label="amplihack-agent-eval\n14 imports"];
        copilot_sdk [label="github-copilot-sdk\n2 imports"];
    }

    subgraph cluster_runtime {
        label="Runtime Binaries (Rust)";
        style=filled; fillcolor="#f0fff0";
        recipe_runner [label="recipe-runner-rs\nv0.3.4"];
        amplihack_cli [label="amplihack CLI"];
        amplihack_hooks [label="amplihack-hooks"];
    }

    subgraph cluster_core {
        label="amplihack Core";
        style=filled; fillcolor="#fffff0";
        recipes [label="recipes/"];
        launcher [label="launcher/"];
        cli [label="cli.py"];
        install [label="install.py"];
        memory [label="memory/"];
        fleet [label="fleet/"];
        safety [label="safety/"];
    }

    recipes -> recipe_runner;
    recipes -> simpleeval;
    launcher -> amplihack_cli;
    cli -> recipes;
    cli -> launcher;
    cli -> install;
    memory -> memory_lib;
    memory -> kuzu;
    fleet -> azure_identity;
    fleet -> docker;
}
