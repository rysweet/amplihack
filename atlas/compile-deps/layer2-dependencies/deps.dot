digraph dependencies {
    rankdir=TD
    node [shape=box style=filled fontname="Helvetica" fontsize=10]
    edge [fontname="Helvetica" fontsize=8]
    compound=true

    // Core package
    subgraph cluster_core {
        label="amplihack Core"
        style=filled fillcolor="#E8F4FD"
        init [label="__init__.py" fillcolor="#AED6F1"]
        cli [label="cli.py" fillcolor="#AED6F1"]
        session [label="session.py" fillcolor="#AED6F1"]
        install [label="install.py" fillcolor="#AED6F1"]
        settings [label="settings.py" fillcolor="#AED6F1"]
        health [label="health_check.py" fillcolor="#AED6F1"]
        dep_check [label="dep_check.py" fillcolor="#AED6F1"]
    }

    // Internal modules
    subgraph cluster_modules {
        label="Internal Modules"
        style=filled fillcolor="#E8F8E8"
        launcher [label="launcher/" fillcolor="#A9DFBF"]
        hooks [label="hooks/" fillcolor="#A9DFBF"]
        proxy_mod [label="proxy/" fillcolor="#A9DFBF"]
        memory [label="memory/" fillcolor="#A9DFBF"]
        security [label="security/" fillcolor="#A9DFBF"]
        safety [label="safety/" fillcolor="#A9DFBF"]
        uvx [label="uvx/" fillcolor="#A9DFBF"]
        fleet [label="fleet/" fillcolor="#A9DFBF"]
        recipes [label="recipes/" fillcolor="#A9DFBF"]
        meta_delegation [label="meta_delegation/" fillcolor="#A9DFBF"]
        plugin_mgr [label="plugin_manager/" fillcolor="#A9DFBF"]
        bundle_gen [label="bundle_generator/" fillcolor="#A9DFBF"]
        goal_agent [label="goal_agent_generator/" fillcolor="#A9DFBF"]
        knowledge [label="knowledge_builder/" fillcolor="#A9DFBF"]
        vendor [label="vendor/blarify/" fillcolor="#A9DFBF"]
        docker_mod [label="docker/" fillcolor="#A9DFBF"]
        utils [label="utils/" fillcolor="#A9DFBF"]
    }

    // External deps
    subgraph cluster_external {
        label="External Dependencies"
        style=filled fillcolor="#FEF5E7"
        flask [label="flask" fillcolor="#FAD7A0"]
        fastapi [label="fastapi" fillcolor="#FAD7A0"]
        litellm [label="litellm" fillcolor="#FAD7A0"]
        kuzu_dep [label="kuzu" shape=cylinder fillcolor="#FAD7A0"]
        claude_sdk [label="claude-agent-sdk" fillcolor="#FAD7A0"]
        langchain [label="langchain" fillcolor="#FAD7A0"]
        tree_sitter [label="tree-sitter" fillcolor="#FAD7A0"]
        docker_dep [label="docker" fillcolor="#FAD7A0"]
        azure_id [label="azure-identity" fillcolor="#FAD7A0"]
        memory_lib [label="amplihack-memory-lib" fillcolor="#FAD7A0"]
    }

    // Key edges
    cli -> launcher
    cli -> docker_mod
    cli -> proxy_mod
    launcher -> session
    launcher -> hooks
    session -> memory
    memory -> kuzu_dep
    memory -> memory_lib
    proxy_mod -> fastapi
    proxy_mod -> flask
    proxy_mod -> litellm
    proxy_mod -> azure_id
    fleet -> claude_sdk
    vendor -> langchain
    vendor -> tree_sitter
    docker_mod -> docker_dep
    knowledge -> vendor
}
