# ============================================================================
# Azure Service Principal Credentials
# ============================================================================
# Required for remote execution on Azure VMs

# Azure AD Tenant ID (Directory ID)
AZURE_TENANT_ID=your-tenant-id-here

# Service Principal Application (Client) ID
AZURE_CLIENT_ID=your-client-id-here

# Service Principal Client Secret Value
AZURE_CLIENT_SECRET=your-client-secret-here

# Azure Subscription ID
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# Optional: Default Resource Group
# AZURE_RESOURCE_GROUP=your-resource-group-name

# ----------------------------------------------------------------------------
# HOW TO GET THESE VALUES:
# ----------------------------------------------------------------------------
#
# 1. Create Service Principal:
#    az ad sp create-for-rbac --name "amplihack-remote-exec" \
#      --role Contributor \
#      --scopes /subscriptions/YOUR_SUBSCRIPTION_ID
#
# 2. The command outputs:
#    {
#      "appId": "<your-client-id>",          # Use for AZURE_CLIENT_ID
#      "displayName": "amplihack-remote-exec",
#      "password": "<your-client-secret>",   # Use for AZURE_CLIENT_SECRET
#      "tenant": "<your-tenant-id>"          # Use for AZURE_TENANT_ID
#    }
#
# 3. Get Subscription ID:
#    az account show --query id -o tsv
#
# ----------------------------------------------------------------------------
# SECURITY NOTES:
# ----------------------------------------------------------------------------
#
# - NEVER commit .env files to git (already in .gitignore)
# - Rotate secrets regularly (90 days recommended)
# - Use minimum required permissions (Contributor on specific resource group)
# - Store backups encrypted
# - Revoke unused Service Principals

# ============================================================================
# Amplihack Core Configuration
# ============================================================================

# Root of the amplihack installation (for asset lookup).
# Required by the recipe runner and orchestrator scripts.
# AMPLIHACK_HOME=/home/user/src/amplihack

# Which agent binary to use for nested workflow sessions.
# Values: claude, copilot, amplifier
# AMPLIHACK_AGENT_BINARY=copilot

# Maximum recursion depth for nested agent sessions (default: 3).
# AMPLIHACK_MAX_DEPTH=3

# Maximum concurrent agent sessions (default: 10).
# AMPLIHACK_MAX_SESSIONS=10

# Run in non-interactive mode — skip all prompts (set to 1 to enable).
# AMPLIHACK_NONINTERACTIVE=0

# Enable debug logging.
# AMPLIHACK_DEBUG=0

# ============================================================================
# Session & Execution
# ============================================================================

# Current session nesting depth (set automatically by the launcher).
# AMPLIHACK_SESSION_DEPTH=0

# Tree identifier for multi-session tracking (set automatically).
# AMPLIHACK_TREE_ID=

# Execution mode override.
# AMPLIHACK_MODE=

# Skip the reflection phase after workflow completion.
# AMPLIHACK_SKIP_REFLECTION=0

# ============================================================================
# Memory & Knowledge Graph
# ============================================================================

# Memory backend type (e.g., kuzu, file).
# AMPLIHACK_MEMORY_BACKEND=kuzu

# Enable/disable memory features (default: enabled when lib is installed).
# AMPLIHACK_MEMORY_ENABLED=1

# Path to the graph database (Kuzu).
# AMPLIHACK_GRAPH_DB_PATH=

# Path to the Kuzu database file.
# AMPLIHACK_KUZU_DB_PATH=

# Enable Neo4j-backed memory (set to 1 to enable).
# AMPLIHACK_ENABLE_NEO4J_MEMORY=0

# ============================================================================
# Observability (OpenTelemetry)
# ============================================================================

# Enable OpenTelemetry tracing and metrics.
# AMPLIHACK_OTEL_ENABLED=0

# OTLP collector endpoint (gRPC or HTTP).
# AMPLIHACK_OTEL_OTLP_ENDPOINT=http://localhost:4317

# OTLP protocol: grpc or http/protobuf.
# AMPLIHACK_OTEL_OTLP_PROTOCOL=grpc

# ============================================================================
# LLM Configuration
# ============================================================================

# Default model for LLM calls.
# AMPLIHACK_DEFAULT_MODEL=

# LLM request timeout in seconds.
# AMPLIHACK_LLM_TIMEOUT=120

# ============================================================================
# XPIA Security (Cross-Platform Injection Attack Prevention)
# ============================================================================

# Enable XPIA security layer (default: true).
# XPIA_ENABLED=true

# Security level: MINIMAL, MODERATE, HIGH, CRITICAL (default: MODERATE).
# XPIA_SECURITY_LEVEL=MODERATE
